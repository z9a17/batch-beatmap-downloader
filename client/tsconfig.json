{
  "compilerOptions": {
    "allowJs": false,
    "target": "ES2022",
    "lib": ["DOM", "ES2023"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
      "node_modules",
      "**/*.spec.ts"
  ]
}
