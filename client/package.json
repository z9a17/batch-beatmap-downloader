{
  "name": "batch-beatmap-downloader-community",
  "productName": "Batch Beatmap Downloader Community",
  "version": "1.4.0-alpha.9",
  "description": "A desktop app for discovering and downloading osu! beatmaps in bulk.",
  "main": ".webpack/main",
  "repository": {
    "type": "git",
    "url": "https://github.com/z9a17/batch-beatmap-downloader.git"
  },
  "scripts": {
    "start": "electron-forge start",
    "build:icons": "node scripts/build-icon.mjs",
    "lint": "cross-env NODE_ENV=development eslint \"src/**/*.{ts,tsx}\" --cache",
    "typecheck": "tsc --noEmit",
    "smoke:win": "node scripts/smoke-packaged.mjs",
    "smoke:installer:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-installer.ps1",
    "package:mac": "electron-forge package --platform darwin",
    "package:linux": "electron-forge package --platform linux",
    "package:win": "electron-forge package --platform win32",
    "make:mac": "electron-forge make --platform darwin",
    "make:linux": "electron-forge make --platform linux",
    "make:win": "npm run package:win && electron-builder --win nsis --x64 --prepackaged \"out/Batch Beatmap Downloader Community-win32-x64\" --config .config/electron-builder.yml --publish never",
    "publish:mac": "electron-forge publish --platform darwin",
    "publish:linux": "electron-forge publish --platform linux",
    "publish:win": "npm run package:win && electron-builder --win nsis --x64 --prepackaged \"out/Batch Beatmap Downloader Community-win32-x64\" --config .config/electron-builder.yml --publish always"
  },
  "keywords": [],
  "author": {
    "name": "Batch Beatmap Downloader Community"
  },
  "license": "MIT",
  "config": {
    "forge": "./.config/forge.config.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "singleQuote": false
  },
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/humanize-duration": "^3.27.4",
    "@types/is-number": "^7.0.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.7.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.19",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.3",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "compress-json": "^3.4.0",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.4",
    "electron-persist-secure": "^1.3.0",
    "electron-settings": "^4.0.4",
    "electron-updater": "^6.8.9",
    "humanize-duration": "^3.34.0",
    "ipc-node-go": "^0.2.0",
    "is-number": "^7.0.0",
    "lodash": "^4.18.1",
    "nanoid": "^6.0.0",
    "nodejs-file-downloader": "^4.13.0",
    "osu-buffer": "^2.0.2",
    "rc-slider": "^11.1.9",
    "react": "^19.2.7",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-select": "^5.10.2",
    "react-switch": "^7.1.0",
    "react-toastify": "^11.1.0",
    "utf8-string-bytes": "^1.0.3",
    "uuid": "^14.0.1"
  }
}
